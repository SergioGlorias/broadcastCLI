{
  "name": "libroadcast-cli",
  "version": "2.12.0",
  "description": "CLI to help with broadcast maintenance on Lichess",
  "main": "dist/index.js",
  "keywords": [
    "lichess",
    "broadcast",
    "cli"
  ],
  "author": "Sérgio Glórias",
  "license": "MIT",
